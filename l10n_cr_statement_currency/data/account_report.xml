<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="statement_col_date" model="account.report.column">
        <field name="name">Fecha</field>
        <field name="expression_label">fecha</field>
        <field name="sequence">20</field>
    </record>

    <record id="statement_col_due_date" model="account.report.column">
        <field name="name">Vencimiento</field>
        <field name="expression_label">fecha_vencimiento</field>
        <field name="sequence">30</field>
    </record>

    <record id="statement_col_days" model="account.report.column">
        <field name="name">Días</field>
        <field name="expression_label">dias_vencidos</field>
        <field name="sequence">35</field>
        <field name="figure_type">integer</field>
    </record>

    <record id="statement_col_original" model="account.report.column">
        <field name="name">Monto original</field>
        <field name="expression_label">importe_original</field>
        <field name="sequence">40</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="statement_col_balance" model="account.report.column">
        <field name="name">Saldo</field>
        <field name="expression_label">saldo</field>
        <field name="sequence">50</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="statement_report" model="account.report">
        <field name="name">Estado de cuenta (moneda original)</field>
        <field name="filter_date_range" eval="False"/>
        <field name="filter_journals" eval="True"/>
        <field name="filter_partner" eval="True"/>
        <field name="filter_unfold_all" eval="True"/>
        <field name="filter_multi_company">selector</field>
        <field name="default_opening_date_filter">today</field>
        <field name="load_more_limit" eval="80"/>
        <field name="column_ids" eval="[(6, 0, [
            ref('statement_col_date'),
            ref('statement_col_due_date'),
            ref('statement_col_days'),
            ref('statement_col_original'),
            ref('statement_col_balance')
        ])]"/>
        <field name="custom_handler_model_id" ref="model_account_outstanding_original_currency_report_handler"/>
    </record>

    <record id="statement_line_base" model="account.report.line">
        <field name="name">Estado de cuenta (moneda original)</field>
        <field name="report_id" ref="statement_report"/>
        <field name="groupby">partner_id,id</field>
    </record>

    <record id="action_statement_report" model="ir.actions.client">
        <field name="name">Estado de cuenta (moneda original)</field>
        <field name="tag">account_report</field>
        <field name="context" eval="{'report_id': ref('statement_report')}"/>
    </record>

    <menuitem
        id="menu_statement_report"
        name="Estado de cuenta (moneda original)"
        parent="account.menu_finance_reports"
        action="action_statement_report"
        sequence="95"
        groups="account.group_account_readonly"
    />
</odoo>
